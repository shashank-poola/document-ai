# Application
APP_NAME=document-intelligence
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Storage
STORAGE_ROOT=./data
MAX_UPLOAD_SIZE_MB=50

# Redis / Job Queue (ARQ — Python Redis queue, BullMQ-equivalent pattern)
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=document-processing
JOB_TIMEOUT_SECONDS=600
JOB_MAX_RETRIES=3

# OCR (PaddleOCR)
OCR_LANG=en
OCR_USE_GPU=false
OCR_DPI=200

# Processing
REVIEW_CONFIDENCE_THRESHOLD=0.75
